DOTAHeroBox {
    width: 1fr;
    height: 7;
    border: solid $panel;
    padding: 1 2;
    content-align: center middle;
    text-align: center;
    background: $surface;
    margin: 0 1;
}

DOTALeaderboard {
    width: 3fr;
    padding: 0 1;
}

DOTALeaderboard > .dota-lb-title {
    color: $text-muted;
    padding: 0 1;
    margin: 0 0 1 0;
}

DOTALeaderboard DataTable {
    height: 1fr;
    padding: 0 0;
    background: $background;
    scrollbar-size: 1 1;
}

DOTASparklines {
    height: auto;
    padding: 0 1;
    content-align: center top;
}

DOTASparklines > .dota-chart-title {
    color: $text-muted;
}

DOTASignals {
    height: 1fr;
    padding: 0 1;
    margin: 1 0 0 0;
    overflow-y: auto;
    content-align: center top;
}

DOTASignals > .dota-sig-title {
    color: $text-muted;
}

DOTAActivityFeed {
    width: 3fr;
    padding: 0 1;
}

DOTAActivityFeed > .dota-feed-title {
    color: $text-muted;
    margin: 0 0 1 0;
}

DOTAActivityFeed RichLog {
    background: $background;
    scrollbar-size: 1 1;
}

DOTABestPlays {
    width: 2fr;
    padding: 0 1;
    content-align: center top;
}

DOTABestPlays > .dota-bp-title {
    color: $text-muted;
}

/* ── OCM screen ────────────────────────────────────────────────────── */

OCMHeroMetrics {
    height: 7;
    padding: 0 1;
    margin: 1 0 0 0;
}

OCMHeroBox {
    width: 1fr;
    height: 7;
    border: solid $panel;
    padding: 1 2;
